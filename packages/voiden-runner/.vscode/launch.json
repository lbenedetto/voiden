{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug voiden-runner",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "run","--show-req", "--show-res"],
      "args": ["${input:voidFile}"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}"
    }
  ],
  "inputs": [
    {
      "id": "voidFile",
      "type": "promptString",
      "description": "Enter the .void file to debug",
      "default": "GRPC.void"
    }
  ]
}
